            position: absolute;
            top: 15px;
            left: 15px;
            right: 15px;
            bottom: 15px;
            border-radius: 50%;
            background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
            overflow: hidden;
