 15px;\n            transform: translateY(-50%);\n            background: rgba(10, 10, 15, 0.85);\n            padding: 10px 24px;\n            border-radius: 6px;\n            border: 1px solid #333;\n            box-shadow: \n                inset 0 2px 8px rgba(0,0,0,0.8),\n                0 0 15px rgba(0, 255, 136, 0.1);\n            z-index: 2;\n        }\n\n        .rpm-value {\n            font-family: 'Orbitron', monospace;\n            font-size: 28px;\n            font-weight: 700;\n            color: #00ff88;\n            text-shadow: 0 0 20px rgba(0, 255, 136, 0.8);\n            letter-spacing: 2px;\n        }\n\n        .rpm-label {\n            font-family: 'Inter', sans-serif;\n            font-size: 10px;\n            color: #888;\n            text-align: center;\n            margin-top: 2px;\n            letter-spacing: 3px;\n        }\n\n        .glow-ring {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 500px;\n            height: 500px;\n            border-radius: 50%;\n            background: radial-gradient(circle, rgba(255, 51, 102, 0.1) 0%, transparent 70%);\n            pointer-events: none;\n            animation: pulse 2s ease-in-out infinite;\n        }\n\n        @keyframes pulse {\n            0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }\n            50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.05); }\n        }\n\n        .needle-glow {\n            filter: drop-shadow(0 0 8px rgba(255, 51, 102, 0.9)) drop-shadow(0 0 20px rgba(255, 51, 102, 0.5));\n        }\n\n        .center-hub {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            z-index: 10;\n        }\n\n        .gear-display {\n            position: absolute;\n            top: 50%;\n            left: auto;\n            right: 15px;\n            transform: translateY(-50%);\n            margin-top: 75px;\n            background: rgba(10, 10, 15, 0.85);\n            padding: 8px 16px;\n            border-radius: 6px;\n            border: 1px solid #333;\n            box-shadow: \n                inset 0 2px 8px rgba(0,0,0,0.8),\n                0 0 15px rgba(0, 255, 136, 0.1);\n            z-index: 2;\n        }\n\n        .gear-label {\n            font-family: 'Inter', sans-serif;\n            font-size: 9px;\n            color: #666;\n            text-align: center;\n            letter-spacing: 3px;\n            margin-bottom: 4px;\n        }\n\n        .gear-indicators {\n            display: flex;\n            gap: 6px;\n        }\n\n        .gear-digit {\n            font-family: 'Orbitron', monospace;\n            font-size: 14px;\n            font-weight: 700;\n            color: #333;\n            background: rgba(30, 30, 40, 0.5);\n            padding: 4px 8px;\n            border-radius: 3px;\n            border: 1px solid #222;\n            min-width: 24px;\n            text-align: center;\n            transition: all 0.15s ease;\n        }\n\n        .gear-digit.active {\n            color: #00ff88;\n            background: rgba(0, 255, 136, 0.15);\n            border-color: #00ff88;\n            text-shadow: 0 0 10px rgba(0, 255, 136, 0.8);\n            box-shadow: 0 0 10px rgba(0, 255, 136, 0.3);\n        }\n\n        .center-hub svg {\n            filter: drop-shadow(0 3px 6px rgba(0,0,0,0.5));\n        }\n\n        /* Tick mark styles */\n        .tick-major {\n            stroke: #ffffff;\n            stroke-width: 3;\n        }\n        .tick-minor {\n            stroke: #888888;\n            stroke-width: 1.5;\n        }\n        .tick-label {\n            font-family: 'Orbitron', monospace;\n            font-size: 18px;\n            fill: #e0e0e0;\n            text-anchor: middle;\n        }\n        .redline-tick {\n            stroke: #ff4d4d;\n            stroke-width: 3;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"glow-ring\"></div>\n    <div class=\"gauge-container\">\n        <div class=\"gauge-bezel\"></div>\n        <div class=\"gauge-face\">\n            <!-- Digital readout - positioned behind needle -->\n            <div class=\"digital-readout\">\n                <div class=\"rpm-value\" id=\"rpmDisplay\">0000</div>\n                <div class=\"rpm-label\">RPM × 1000</div>\n            </div>\n            \n            <div class=\"gear-display\">\n                <div class=\"gear-label\">GEAR</div>\n                <div class=\"gear-indicators\" id=\"gearIndicators\">\n                    <div class=\"gear-digit\" data-gear=\"1\">1</div>\n                    <div class=\"gear-digit\" data-gear=\"2\">2</div>\n                    <div class=\"gear-digit\" data-gear=\"3\">3</div>\n                    <div class=\"gear-digit\" data-gear=\"4\">4</div>\n                    <div class=\"gear-digit\" data-gear=\"5\">5</div>\n                    <div class=\"gear-digit\" data-gear=\"6\">6</div>\n                </div>\n            </div>\n            \n            <svg class=\"gauge-svg\" viewBox=\"0 0 420 420\" id=\"gauge\">\n                <!-- Red zone arc -->\n                <path id=\"redzone\" d=\"\" fill=\"none\" stroke=\"#ff4d4d\" stroke-width=\"25\" opacity=\"0.6\"/>\n                \n                <!-- Background arc -->\n                <path id=\"bgArc\" d=\"\" fill=\"none\" stroke=\"#2a2a3a\" stroke-width=\"25\"/>\n                \n                <!-- Glow arc (underneath everything) -->\n                <path id=\"glowArc\" d=\"\" fill=\"none\" stroke=\"url(#glowGradient)\" stroke-width=\"8\" opacity=\"0.5\"/>\n                \n                <defs>\n                    <linearGradient id=\"glowGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                        <stop offset=\"0%\" style=\"stop-color:#00ff88;stop-opacity:0\"/>\n                        <stop offset=\"50%\" style=\"stop-color:#00ff88;stop-opacity:1\"/>\n                        <stop offset=\"100%\" style=\"stop-color:#ff3366;stop-opacity:0\"/>\n                    </linearGradient>\n                    <filter id=\"needleGlow\">\n                        <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\"/>\n                        <feMerge>\n                            <feMergeNode in=\"coloredBlur\"/>\n                            <feMergeNode in=\"SourceGraphic\"/>\n                        </feMerge>\n                    </filter>\n                    <linearGradient id=\"hubGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n                        <stop offset=\"0%\" style=\"stop-color:#4a4a5a\"/>\n                        <stop offset=\"50%\" style=\"stop-color:#2a2a3a\"/>\n                        <stop offset=\"100%\" style=\"stop-color:#1a1a2a\"/>\n                    </linearGradient>\n                </defs>\n                \n                <!-- Tick marks and labels will be added via JS -->\n            </svg>\n            \n            <!-- Center hub - sits above needle -->\n            <div class=\"center-hub\">\n                <svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\">\n                    <circle cx=\"40\" cy=\"40\" r=\"38\" fill=\"url(#hubGradient)\" stroke=\"#555\" stroke-width=\"2\"/>\n                    <circle cx=\"40\" cy=\"40\" r=\"28\" fill=\"#1a1a2a\" stroke=\"#333\" stroke-width=\"1\"/>\n                    <circle cx=\"40\" cy=\"40\" r=\"10\" fill=\"#ff3366\"/>\n                </svg>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Gauge configuration\n        const config = {\n            minRPM: 0,\n            maxRPM: 12,\n            redlineRPM: 10,\n            startAngle: 135,\n            endAngle: 405,\n            centerX: 210,\n            centerY: 210,\n            radius: 160\n        };\n\n        // State\n        let currentRPM = 1.5; // Start at idle\n        let targetRPM = 1.5;\n        let lastUpdate = Date.now();\n\n        // Perlin-like noise for smooth fluctuations\n        class SimpleNoise {\n            constructor() {\n                this.offset = Math.random() * 1000;\n                this.speed = 0.001;\n            }\n            \n            get() {\n                this.offset += this.speed;\n                // Simple smoothed noise\n                return Math.sin(this.offset) * 0.5 + \n                       Math.sin(this.offset * 2.3) * 0.3 + \n                       Math.sin(this.offset * 0.7) * 0.2;\n            }\n        }\n\n        const noise = new SimpleNoise();\n\n        // Calculate arc path for gauge background\n        function describeArc(startAngle, endAngle, radius) {\n            const start = polarToCartesian(config.centerX, config.centerY, radius, endAngle);\n            const end = polarToCartesian(config.centerX, config.centerY, radius, startAngle);\n            const largeArcFlag = endAngle - startAngle <= 180 ? \"0\" : \"1\";\n            \n            return [\n                \"M\", start.x, start.y,\n                \"A\", radius, radius, 0, largeArcFlag, 0, end.x, end.y\n            ].join(\" \");\n        }\n\n        function polarToCartesian(centerX, centerY, radius, angleInDegrees) {\n            const angleInRadians = (angleInDegrees - 90) * Math.PI / 180.0;\n            return {\n                x: centerX + (radius * Math.cos(angleInRadians)),\n                y: centerY + (radius * Math.sin(angleInRadians))\n            };\n        }\n\n        function angleToRPM(angle) {\n            const angleRange = config.endAngle - config.startAngle;\n            const rpmRange = config.maxRPM - config.minRPM;\n            const normalizedAngle = angle - config.startAngle;\n            return (normalizedAngle / angleRange) * rpmRange + config.minRPM;\n        }\n\n        function rpmToAngle(rpm) {\n            const angleRange = config.endAngle - config.startAngle;\n            const rpmRange = config.maxRPM - config.minRPM;\n            return config.startAngle + ((rpm - config.minRPM) / rpmRange) * angleRange;\n        }\n\n        // Create tick marks\n        function createTicks() {\n            const svg = document.getElementById('gauge');\n            \n            for (let rpm = 0; rpm <= config.maxRPM; rpm += 0.5) {\n                const angle = rpmToAngle(rpm);\n                const isMajor = rpm % 1 === 0;\n                const isRedline = rpm >= config.redlineRPM;\n                \n                const innerRadius = isMajor ? config.radius - 30 : config.radius - 20;\n                const outerRadius = config.radius - 5;\n                \n                const inner = polarToCartesian(config.centerX, config.centerY, innerRadius, angle);\n                const outer = polarToCartesian(config.centerX, config.centerY, outerRadius, angle);\n                \n                const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n                line.setAttribute(\"x1\", inner.x);\n                line.setAttribute(\"y1\", inner.y);\n                line.setAttribute(\"x2\", outer.x);\n                line.setAttribute(\"y2\", outer.y);\n                line.setAttribute(\"class\", isRedline ? \"redline-tick\" : (isMajor ? \"tick-major\" : \"tick-minor\"));\n                svg.appendChild(line);\n                \n                // Add labels for major ticks\n                if (isMajor && rpm <= 10) {\n                    const labelRadius = config.radius - 50;\n                    const labelPos = polarToCartesian(config.centerX, config.centerY, labelRadius, angle);\n                    \n                    const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n                    text.setAttribute(\"x\", labelPos.x);\n                    text.setAttribute(\"y\", labelPos.y);\n                    text.setAttribute(\"class\", \"tick-label\");\n                    text.setAttribute(\"fill\", isRedline ? \"#ff4d4d\" : \"#e0e0e0\");\n                    text.textContent = rpm;\n                    svg.appendChild(text);\n                }\n            }\n        }\n\n        // Create needle\n        let needle;\n        function createNeedle() {\n            const svg = document.getElementById('gauge');\n            \n            needle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n            needle.setAttribute(\"class\", \"needle-glow\");\n            needle.setAttribute(\"filter\", \"url(#needleGlow)\");\n            \n            // Main needle body\n            const needlePath = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n            needlePath.setAttribute(\"d\", \"M210 210 L200 180 L210 60 L220 180 Z\");\n            needlePath.setAttribute(\"fill\", \"#ff3366\");\n            needle.appendChild(needlePath);\n            \n            // Center cap\n            const cap = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n            cap.setAttribute(\"cx\", \"210\");\n            cap.setAttribute(\"cy\", \"210\");\n            cap.setAttribute(\"r\", \"12\");\n            cap.setAttribute(\"fill\", \"#ff3366\");\n            needle.appendChild(cap);\n            \n            svg.appendChild(needle);\n        }\n\n        // Update gauge\n        function updateGauge() {\n            // Random target changes\n            if (Math.random() < 0.01) {\n                const change = (Math.random() - 0.3) * 2;\n                targetRPM = Math.max(0.5, Math.min(11, targetRPM + change));\n            }\n            \n            // Add noise to target\n            const noiseValue = noise.get() * 0.15;\n            const effectiveTarget = targetRPM + noiseValue;\n            \n            // Smooth interpolation (spring-like)\n            const diff = effectiveTarget - currentRPM;\n            currentRPM += diff * 0.08;\n            \n            // Update needle rotation\n            const angle = rpmToAngle(currentRPM);\n            needle.setAttribute(\"transform\", `rotate(${angle}, 210, 210)`);\n            \n            // Update glow arc\n            const glowArc = document.getElementById('glowArc');\n            const currentAngle = config.startAngle + ((currentRPM / config.maxRPM) * (config.endAngle - config.startAngle));\n            const arcEnd = Math.min(currentAngle, config.redlineRPM ? rpmToAngle(config.redlineRPM) : config.endAngle);\n            glowArc.setAttribute(\"d\", describeArc(config.startAngle, arcEnd, config.radius - 12));\n            \n            // Update digital display\n            const displayRPM = Math.round(currentRPM * 1000);\n            document.getElementById('rpmDisplay').textContent = displayRPM.toString().padStart(4, '0');\n            \n            // Adjust glow color based on RPM\n            const glowColor = currentRPM >= config.redlineRPM ? \n                `rgba(255, 77, 77, ${0.3 + (currentRPM - config.redlineRPM) * 0.1})` :\n                `rgba(0, 255, 136, 0.3)`;\n            \n            requestAnimationFrame(updateGauge);\n        }\n\n        // Initialize\n        function init() {\n            // Set up background arcs\n            document.getElementById('bgArc').setAttribute(\"d\", describeArc(config.startAngle, config.endAngle, config.radius));\n            \n            const redlineAngle = rpmToAngle(config.redlineRPM);\n            document.getElementById('redzone').setAttribute(\"d\", describeArc(redlineAngle, config.endAngle, config.radius));\n            \n            createTicks();\n            createNeedle();\n            \n            // Initial position\n            const initialAngle = rpmToAngle(currentRPM);\n            needle.setAttribute(\"transform\", `rotate(${initialAngle}, 210, 210)`);\n            \n            updateGauge();\n        }\n\n        init();\n    </script>\n</body>\n</html>"
}

