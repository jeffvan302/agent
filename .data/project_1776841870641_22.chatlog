```svg
<svg viewBox="0 0 300 300" width="350" height="350" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Metallic bezel gradient -->
    <linearGradient id="bezelGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4a4a5a"/>
      <stop offset="50%" style="stop-color:#2a2a3a"/>
      <stop offset="100%" style="stop-color:#1a1a2a"/>
    </linearGradient>
    
    <!-- Face gradient -->
    <radialGradient id="faceGrad" cx="50%" cy="50%" r="60%">
      <stop offset="0%" style="stop-color:#252530"/>
      <stop offset="100%" style="stop-color:#0f0f1a"/>
    </radialGradient>
    
    <!-- Green glow for safe zone -->
    <filter id="greenGlow">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <!-- Red zone glow -->
    <filter id="redGlow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <!-- Needle glow -->
    <filter id="needleGlow">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Outer glow ring -->
  <circle cx="150" cy="150" r="145" fill="none" stroke="rgba(255,200,0,0.1)" stroke-width="20">
    <animate attributeName="opacity" values="0.3;0.7;0.3" dur="3s" repeatCount="indefinite"/>
  </circle>
  
  <!-- Bezel -->
  <circle cx="150" cy="150" r="140" fill="url(#bezelGrad)" stroke="#555" stroke-width="2"/>
  
  <!-- Face -->
  <circle cx="150" cy="150" r="125" fill="url(#faceGrad)"/>
  
  <!-- Colored zones on the dial -->
  <!-- Safe zone (green) - 0 to 60 PSI -->
  <path d="M 150 150 L 62.5 82.5 A 100 100 0 0 1 150 50 Z" fill="rgba(0,255,136,0.15)" stroke="rgba(0,255,136,0.5)" stroke-width="1"/>
  
  <!-- Warning zone (yellow) - 60 to 80 PSI -->
  <path d="M 150 150 L 150 50 A 100 100 0 0 1 237.5 82.5 Z" fill="rgba(255,255,0,0.1)" stroke="rgba(255,255,0,0.4)" stroke-width="1"/>
  
  <!-- Danger zone (red) - 80 to 100 PSI -->
  <path d="M 150 150 L 237.5 82.5 A 100 100 0 0 1 150 250 Z" fill="rgba(255,0,0,0.15)" stroke="rgba(255,0,0,0.5)" stroke-width="1"/>
  
  <!-- Tick marks and labels -->
  <g id="tickMarks" transform="rotate(-135, 150, 150)">
    <!-- Will be added via animation -->
  </g>
  
  <!-- Major tick marks (every 10 PSI) -->
  <g font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#ccc" text-anchor="middle">
    <!-- 0 PSI - bottom left -->
    <line x1="70" y1="215" x2="85" y2="205" stroke="#fff" stroke-width="2"/>
    <text x="55" y="218">0</text>
    
    <!-- 20 PSI -->
    <line x1="52" y1="150" x2="67" y2="150" stroke="#fff" stroke-width="2"/>
    <text x="35" y="154">20</text>
    
    <!-- 40 PSI - top -->
    <line x1="150" y1="55" x2="150" y2="70" stroke="#fff" stroke-width="2"/>
    <text x="150" y="42">40</text>
    
    <!-- 60 PSI -->
    <line x1="248" y1="150" x2="233" y2="150" stroke="#fff" stroke-width="2"/>
    <text x="265" y="154">60</text>
    
    <!-- 80 PSI -->
    <line x1="215" y1="215" x2="200" y2="205" stroke="#ffcc00" stroke-width="2"/>
    <text x="225" y="228" fill="#ffcc00">80</text>
    
    <!-- 100 PSI - bottom right -->
    <line x1="150" y1="245" x2="150" y2="230" stroke="#ff4d4d" stroke-width="2"/>
    <text x="150" y="268" fill="#ff4d4d">100</text>
  </g>
  
  <!-- Minor tick marks -->
  <g stroke="#666" stroke-width="1">
    <line x1="65" y1="195" x2="75" y2="190" transform="rotate(18, 150, 150)"/>
    <line x1="62" y1="175" x2="72" y2="172" transform="rotate(36, 150, 150)"/>
    <line x1="66" y1="157" x2="76" y2="155" transform="rotate(54, 150, 150)"/>
    <line x1="77" y1="140" x2="84" y2="140" transform="rotate(72, 150, 150)"/>
    
    <line x1="90" y1="80" x2="98" y2="85" transform="rotate(-18, 150, 150)"/>
    <line x1="113" y1="62" x2="118" y2="70" transform="rotate(-36, 150, 150)"/>
    <line x1="138" y1="56" x2="141" y2="64" transform="rotate(-54, 150, 150)"/>
    
    <line x1="190" y1="75" x2="190" y2="85" transform="rotate(-72, 150, 150)"/>
    <line x1="215" y1="95" x2="212" y2="105" transform="rotate(-90, 150, 150)"/>
  </g>
  
  <!-- Center hub -->
  <circle cx="150" cy="150" r="25" fill="#2a2a3a" stroke="#444" stroke-width="1"/>
  <circle cx="150" cy="150" r="8" fill="#ffcc00"/>
  
  <!-- Animated needle - this will wobble randomly -->
  <g id="needle" filter="url(#needleGlow)">
    <path d="M 150 150 L 143 100 L 150 55 L 157 100 Z" fill="#ffcc00">
      <animateTransform attributeName="transform" type="rotate" 
        values="-20; -15; -25; -10; -20; -12; -18; -22; -8; -15; -20"
        dur="2s" repeatCount="indefinite"/>
    </path>
    <circle cx="150" cy="150" r="6" fill="#ffcc00"/>
  </g>
  
  <!-- Label -->
  <text x="150" y="180" font-family="Arial, sans-serif" font-size="11" fill="#888" text-anchor="middle">PSI</text>
  
  <!-- Title -->
  <text x="150" y="265" font-family="Arial, sans-serif" font-size="14" font-weight="bold" fill="#aaa" text-anchor="middle">PRESSURE</text>
</svg>
