  "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Motorcycle RPM Gauge</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@400;500&display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            background: #0a0a0f;\n            background: radial-gradient(ellipse at center, #1a1a2e 0%, #0a0a0f 70%);\n            font-family: 'Inter', sans-serif;\n            overflow: hidden;\n        }\n\n        .gauge-container {\n            position: relative;\n            width: 450px;\n            height: 450px;\n        }\n\n        .gauge-bezel {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            border-radius: 50%;\n            background: linear-gradient(145deg, #3a3a4a, #1a1a2a);\n            box-shadow: \n                0 0 60px rgba(255, 51, 102, 0.15),\n                inset 0 2px 4px rgba(255, 255, 255, 0.1),\n                0 20px 60px rgba(0, 0, 0, 0.8);\n        }\n\n        .gauge-face {\n            position: absolute;\n            top: 15px;\n            left: 15px;\n            right: 15px;\n            bottom: 15px;\n            border-radius: 50%;\n            background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);\n            overflow: hidden;\n        }\n\n        .gauge-svg {\n            width: 100%;\n            height: 100%;\n            position: relative;\n            z-index: 5;\n        }\n\n        .digital-readout {\n            position: absolute;\n            top: 50%;\n            left: auto;\n            right: 15px;\n            transform: translateY(-50%);\n            background: rgba(10, 10, 15, 0.85);\n            padding: 10px 24px;\n            border-radius: 6px;\n            border: 1px solid #333;\n            box-shadow: \n                inset 0 2px 8px rgba(0,0,0,0.8),\n                0 0 15px rgba(0, 255, 136, 0.1);\n            z-index: 2;\n        }\n\n        .rpm-value {\n            font-family: 'Orbitron', monospace;\n            font-size: 28px;\n            font-weight: 700;\n            color: #00ff88;\n            text-shadow: 0 0 20px rgba(0, 255, 136, 0.8);\n            letter-spacing: 2px;\n        }\n\n        .rpm-label {\n            font-family: 'Inter', sans-serif;\n            font-size: 10px;\n            color: #888;\n            text-align: center;\n            margin-top: 2px;\n            letter-spacing: 3px;\n        }\n\n        .glow-ring {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 500px;\n            height: 500px;\n            border-radius: 50%;\n            background: radial-gradient(circle, rgba(255, 51, 102, 0.1) 0%, transparent 70%);\n            pointer-events: none;\n            animation: pulse 2s ease-in-out infinite;\n        }\n\n        @keyframes pulse {\n            0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }\n            50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.05); }\n        }\n\n        .needle-glow {\n            filter: drop-shadow(0 0 8px rgba(255, 51, 102, 0.9)) drop-shadow(0 0 20px rgba(255, 51, 102, 0.5));\n        }\n\n        .center-hub {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            z-index: 10;\n        }\n\n        .gear-display {\n            position: absolute;\n            top: 50%;\n            left: auto;\n            right: 15px;\n            transform: translateY(-50%);\n            margin-top: 75px;\n            background: rgba(10, 10, 15, 0.85);\n            padding: 8px 16px;\n            border-radius: 6px;\n            border: 1px solid #333;\n            box-shadow: \n                inset 0 2px 8px rgba(0,0,0,0.8),\n                0 0 15px rgba(0, 255, 136, 0.1);\n            z-index: 2;\n        }\n\n        .gear-label {\n            font-family: 'Inter', sans-serif;\n            font-size: 9px;\n            color: #666;\n            text-align: center;\n            letter-spacing: 3px;\n            margin-bottom: 4px;\n        }\n\n        .gear-indicators {\n            display: flex;\n            gap: 6px;\n        }\n\n        .gear-digit {\n            font-family: 'Orbitron', monospace;\n            font-size: 14px;\n            font-weight: 700;\n            color: #333;\n            background: rgba(30, 30, 40, 0.5);\n            padding: 4px 8px;\n            border-radius: 3px;\n            border: 1px solid #222;\n            min-width: 24px;\n            text-align: center;\n            transition: all 0.15s ease;\n        }\n\n        .gear-digit.active {\n            color: #00ff88;\n            background: rgba(0, 255, 136, 0.15);\n            border-color: #00ff88;\n            text-shadow: 0 0 10px rgba(0, 255, 136, 0.8);\n            box-shadow: 0 0 10px rgba(0, 255, 136, 0.3);\n        }\n\n        .center-hub svg {\n            filter: drop-shadow(0 3px 6px rgba(0,0,0,0.5));\n        }\n\n        /* Tick mark styles */\n        .tick-major {\n            stroke: #ffffff;\n            stroke-width: 3;\n        }\n        .tick-minor {\n            stroke: #888888;\n            stroke-width: 1.5;\n        }\n        .tick-label {\n            font-family: 'Orbitron', monospace;\n            font-size: 18px;\n            fill: #e0e0e0;\n            text-anchor: middle;\n        }\n        .redline-tick {\n            stroke: #ff4d4d;\n            stroke-width: 3;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"glow-ring\"></div>\n    <div class=\"gauge-container\">\n        <div class=\"gauge-bezel\"></div>\n        <div class=\"gauge-face\">\n            <!-- Digital readout - positioned behind needle -->\n            <div class=\"digital-readout\">\n                <div class=\"rpm-value\" id=\"rpmDisplay\">0000</div>\n                <div class=\"rpm-label\">RPM × 1000</div>\n            </div>\n            \n            <div class=\"gear-display\">\n                <div class=\"gear-label\">GEAR</div>\n                <div class=\"gear-indicators\" id=\"gearIndicators\">\n                    <div class=\"gear-digit\" data-gear=\"1\">1</div>\n                    <div class=\"gear-digit\" data-gear=\"2\">2</div>"
