bool IsAgentHttpsProvider(const ProviderConfig& provider) {
    return NormalizeProviderType(provider.provider_type) == "agent_https";
}

bool IsOAuthProvider(const ProviderConfig& provider) {
    return NormalizeProviderType(provider.provider_type) == "openai_codex_oauth";
}

bool IsLmStudioProvider(const ProviderConfig& provider) {
    return NormalizeProviderType(provider.provider_type) == "lmstudio_local";
}

bool IsOllamaProvider(const ProviderConfig& provider) {
    return NormalizeProviderType(provider.provider_type) == "ollama_local";
}

bool IsBindingProvider(const ProviderConfig& provider) {
    return NormalizeProviderType(provider.provider_type) == "binding_provider";
}

bool IsCatalogDrivenProvider(const ProviderConfig& provider) {
    const std::string normalized = NormalizeProviderType(provider.provider_type);
    return normalized == "openai_codex_oauth" || normalized == "lmstudio_local";
}

std::string ProviderTypeDisplayLabel(const ProviderConfig& provider) {
    const std::string normalized = NormalizeProviderType(provider.provider_type);
    if (normalized == "agent_https") {
        return "Agent HTTPS";
    }
    if (normalized == "openai_codex_oauth") {
        return "OpenAI OAuth";
    }
    if (normalized == "lmstudio_local") {
        return "LM Studio";
    }
    if (normalized == "ollama_local") {
        return "Ollama";
    }
    if (normalized == "ollama_cloud") {
        return "Ollama Cloud";
    }
    if (normalized == "binding_provider") {
        return "Binding Provider";
    }
    return "OpenAI";
}

enum class ProviderEditorKind {
    OpenAICompatible,
    AgentHttps,
    OpenAIOAuth,
    LmStudioLocal,
    OllamaLocal,
    OllamaCloud,
    BindingProvider,
};

ProviderEditorKind ProviderKindFromConfig(const ProviderConfig& provider) {
    const std::string normalized = NormalizeProviderType(provider.provider_type);
    if (normalized == "agent_https") {
        return ProviderEditorKind::AgentHttps;
    }
    if (normalized == "openai_codex_oauth") {
        return ProviderEditorKind::OpenAIOAuth;
    }
    if (normalized == "lmstudio_local") {
        return ProviderEditorKind::LmStudioLocal;
    }
    if (normalized == "ollama_local") {
        return ProviderEditorKind::OllamaLocal;
    }
    if (normalized == "ollama_cloud") {
        return ProviderEditorKind::OllamaCloud;
    }
    if (normalized == "binding_provider") {
        return ProviderEditorKind::BindingProvider;
    }
    return ProviderEditorKind::OpenAICompatible;
}

int ComboIndexFromProviderKind(ProviderEditorKind kind) {
    switch (kind) {
    case ProviderEditorKind::AgentHttps: return 1;
    case ProviderEditorKind::OpenAIOAuth: return 2;
    case ProviderEditorKind::LmStudioLocal: return 3;
    case ProviderEditorKind::OllamaLocal: return 4;
    case ProviderEditorKind::OllamaCloud: return 5;
    case ProviderEditorKind::BindingProvider: return 6;
    case ProviderEditorKind::OpenAICompatible:
    default:
        return 0;
    }
}

ProviderEditorKind ProviderKindFromComboIndex(int index) {
    switch (index) {
    case 1: return ProviderEditorKind::AgentHttps;
    case 2: return ProviderEditorKind::OpenAIOAuth;
    case 3: return ProviderEditorKind::LmStudioLocal;
    case 4: return ProviderEditorKind::OllamaLocal;
    case 5: return ProviderEditorKind::OllamaCloud;
    case 6: return ProviderEditorKind::BindingProvider;
    case 0:
    default:
        return ProviderEditorKind::OpenAICompatible;
    }
}

std::string ProviderTypeFromKind(ProviderEditorKind kind) {
    switch (kind) {
    case ProviderEditorKind::AgentHttps: return "agent_https";
    case ProviderEditorKind::OpenAIOAuth: return "openai_codex_oauth";
    case ProviderEditorKind::LmStudioLocal: return "lmstudio_local";
    case ProviderEditorKind::OllamaLocal: return "ollama_local";
    case ProviderEditorKind::OllamaCloud: return "ollama_cloud";
    case ProviderEditorKind::BindingProvider: return "binding_provider";
    case ProviderEditorKind::OpenAICompatible:
    default:
        return "openai_compatible";
    }
}

