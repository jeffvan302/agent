    std::string worker_name;
    std::string model_name;
    std::string purpose;
    int https_port = 8765;
    std::string shared_secret;
    std::string certificate_fingerprint;
};

std::optional<RemoteWorkerInfo> FetchAgentWorkerHealth(const ProviderConfig& provider, std::string* error);

std::wstring JoinLines(const std::vector<std::wstring>& lines) {
    std::wstring joined;
    for (size_t i = 0; i < lines.size(); ++i) {
        if (i > 0) {
            joined += L"\r\n";
        }
        joined += lines[i];
    }
    return joined;
}

