    case ProviderEditorKind::LmStudioLocal:
        return "http://127.0.0.1:1234/v1";
    case ProviderEditorKind::OllamaLocal:
        return {};
    case ProviderEditorKind::OllamaCloud:
        return "https://ollama.com/api";
    case ProviderEditorKind::OpenAIOAuth:
        return "https://api.openai.com/v1";
    case ProviderEditorKind::OpenAICompatible:
    default:
        return {};
    }
}

std::string DefaultCatalogModeForProviderKind(ProviderEditorKind kind) {
    switch (kind) {
    case ProviderEditorKind::OpenAIOAuth:
        return "bundled";
    case ProviderEditorKind::LmStudioLocal:
        return "remote_endpoint";
    case ProviderEditorKind::AgentHttps:
        return "agent_health";
    case ProviderEditorKind::BindingProvider:
        return "manual";
    case ProviderEditorKind::OllamaLocal:
        return "manual";
    case ProviderEditorKind::OllamaCloud:
        return "manual";
    case ProviderEditorKind::OpenAICompatible:
