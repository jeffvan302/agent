        return "manual";
    }
}

bool ProviderKindUsesOAuth(ProviderEditorKind kind) {
    return kind == ProviderEditorKind::OpenAIOAuth;
}

bool ProviderKindUsesAgentHealth(ProviderEditorKind kind) {
    return kind == ProviderEditorKind::AgentHttps;
}

bool ProviderKindUsesRemoteCatalog(ProviderEditorKind kind) {
    return kind == ProviderEditorKind::LmStudioLocal;
}

std::string JoinUrlAndPort(std::string url, const std::wstring& port_text) {
    url = Trim(url);
    if (url.empty()) {
        url = "https://127.0.0.1";
    }
    if (url.find("://") == std::string::npos) {
        url = "https://" + url;
    }
    while (!url.empty() && url.back() == '/') {
        url.pop_back();
    }
    const auto port = ParseInt(port_text);
    if (!port || *port <= 0) {
        return url;
    }

    URL_COMPONENTSW components{};
    components.dwStructSize = sizeof(components);
    std::wstring wide = Utf8ToWide(url);
    wchar_t host[2048] = {};
    components.lpszHostName = host;
    components.dwHostNameLength = static_cast<DWORD>(std::size(host));
    if (WinHttpCrackUrl(wide.c_str(), static_cast<DWORD>(wide.size()), 0, &components) && components.nPort == INTERNET_DEFAULT_HTTPS_PORT) {
        return url + ":" + std::to_string(*port);
    }
    return url;
}

std::optional<std::filesystem::path> PickRemoteWorkerJson(HWND owner) {
    wchar_t path[MAX_PATH] = {};
    OPENFILENAMEW ofn{};
    ofn.lStructSize = sizeof(ofn);
    ofn.hwndOwner = owner;
    ofn.lpstrFile = path;
    ofn.nMaxFile = static_cast<DWORD>(std::size(path));
    ofn.lpstrFilter = L"Remote Ollama Worker JSON\0*.json\0All Files\0*.*\0";
    ofn.nFilterIndex = 1;
    ofn.Flags = OFN_FILEMUSTEXIST | OFN_PATHMUSTEXIST | OFN_HIDEREADONLY;
    ofn.lpstrTitle = L"Load Remote Ollama Worker JSON";
    if (!GetOpenFileNameW(&ofn)) {
        return std::nullopt;
    }
    return std::filesystem::path(path);
}

